# Обычно не нужен: по умолчанию base='./' (корректно для GitHub Pages в подкаталоге).
# Только если хотите абсолютный base, например для Firebase на корне домена:
# VITE_BASE_PATH=/

# Опционально: свой прокси для MusicBrainz API в проде (CORS)
# VITE_MB_API_BASE=https://your-proxy.example.com/ws/2

# Firebase Web App (опционально). Включите Anonymous в Authentication + Firestore.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
